            "Monthly Data Shape: (48, 5)\n"
          ]
        }
      ],
      "source": [
        "# Load datasets using identical relative paths for both Local and Colab\n",
        "df_daily = pd.read_csv('../Data/clean_daily_ready.csv', parse_dates=['date'], index_col='date')\n",
        "df_monthly = pd.read_csv('../Data/clean_monthly_ready.csv', parse_dates=['date'], index_col='date')\n",
        "\n",
        "print(\"Daily Data Shape:\", df_daily.shape)\n",
        "print(\"Monthly Data Shape:\", df_monthly.shape)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "8sBMh1tYLNbO"
      },
      "source": [
        "## 4. Feature Engineering\n",
        "Constructing lagged features, rolling means, and calendar-based predictors."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 4,
      "metadata": {
        "id": "lQxDaQ5uLNbP",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "58c4d3fb-9f6f-44a6-f341-b73f45a84dec"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Daily Features Shape after dropping NaNs: (1428, 14)\n",
            "Monthly Features Shape after dropping NaNs: (36, 9)\n"
          ]
        }
      ],
      "source": [
        "def create_daily_features(df):\n",
        "    df = df.copy()\n",
        "    # Calendar Features\n",
        "    df['dayofweek'] = df.index.dayofweek\n",
        "    df['month'] = df.index.month\n",
        "    df['quarter'] = df.index.quarter\n",
        "    df['dayofyear'] = df.index.dayofyear\n",
        "    df['is_weekend'] = df['dayofweek'].isin([5, 6]).astype(int)\n",
        "\n",
        "    # Determine the target column for lags\n",
        "    target = 'sales_log' if 'sales_log' in df.columns else 'sales'\n",
        "\n",
        "    # Lag Features (Short-term and weekly memory)\n",
        "    df['lag_1'] = df[target].shift(1)\n",
        "    df['lag_7'] = df[target].shift(7)\n",
        "    df['lag_30'] = df[target].shift(30)\n",
        "\n",
        "    # Rolling Trend Features\n",
        "    df['rolling_mean_7'] = df[target].shift(1).rolling(window=7).mean()\n",
        "    df['rolling_mean_30'] = df[target].shift(1).rolling(window=30).mean()\n",
        "\n",
        "    # Drop rows with NaN values created by shifting\n",
        "    return df.dropna()\n",
        "\n",
        "def create_monthly_features(df):\n",
        "    df = df.copy()\n",
        "    df['month'] = df.index.month\n",
        "    df['quarter'] = df.index.quarter\n",
        "\n",
        "    target = 'sales_log' if 'sales_log' in df.columns else 'sales'\n",
        "    df['lag_1'] = df[target].shift(1)\n",
        "    df['lag_12'] = df[target].shift(12)  # Yearly seasonality\n",
        "    df['rolling_mean_3'] = df[target].shift(1).rolling(window=3).mean()\n",
        "\n",
        "    return df.dropna()\n",
        "\n",
        "df_daily_features = create_daily_features(df_daily)\n",
        "df_monthly_features = create_monthly_features(df_monthly)\n",
        "\n",
        "print(\"Daily Features Shape after dropping NaNs:\", df_daily_features.shape)\n",
        "print(\"Monthly Features Shape after dropping NaNs:\", df_monthly_features.shape)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "N41H5WxOLNbP"
      },
      "source": [
        "## 5. Train-Test Split (Strict Chronological)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "lHtxLyfeLNbP",
        "outputId": "e408c66d-500b-4146-f04c-b25ca158182c"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Daily - Train: (1064, 12) Test: (364, 12)\n",
            "Monthly - Train: (24, 7) Test: (12, 7)\n"
          ]
        }
      ],
      "source": [
        "def split_data(df, target_col='sales_log'):\n",
        "    # Ensure we use chronological splits\n",
        "    train = df.loc['2015-01-01':'2017-12-31']\n",
        "    test = df.loc['2018-01-01':'2018-12-31']\n",
        "\n",
        "    # Separate features (X) and target (y)\n",
        "    drop_cols = ['sales', 'sales_log'] # We drop raw sales to prevent target leakage\n",
        "    X_train = train.drop(columns=[c for c in drop_cols if c in train.columns])\n",
        "    y_train = train[target_col]\n",
        "\n",
        "    X_test = test.drop(columns=[c for c in drop_cols if c in test.columns])\n",
        "    y_test = test[target_col]\n",
        "\n",
        "    return train, test, X_train, y_train, X_test, y_test\n",
        "\n",
        "# Apply splits\n",
        "train_d, test_d, X_train_d, y_train_d, X_test_d, y_test_d = split_data(df_daily_features)\n",
        "train_m, test_m, X_train_m, y_train_m, X_test_m, y_test_m = split_data(df_monthly_features)\n",
        "\n",
        "print(\"Daily - Train:\", X_train_d.shape, \"Test:\", X_test_d.shape)\n",
        "print(\"Monthly - Train:\", X_train_m.shape, \"Test:\", X_test_m.shape)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "rV8ZkOnGLNbQ"
      },
      "source": [
        "## 6. Baseline Models\n",
        "Implementation of Naïve Forecast and Historical Mean."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "id": "fW35wbJ0LNbQ",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "301ef4fd-d92e-4cf3-de2d-d5414176bb16"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "========== DAILY FORECAST BASELINES (Log Scale) ==========\n",
            "Naïve Forecast            | MAE: 1.3022 | RMSE: 1.7334\n",
            "Historical Mean           | MAE: 1.0970 | RMSE: 1.3762\n",
            "\n",
            "========== MONTHLY FORECAST BASELINES (Log Scale) ==========\n",
            "Naïve Forecast            | MAE: 0.4224 | RMSE: 0.5201\n",
            "Historical Mean           | MAE: 0.4718 | RMSE: 0.5734\n"
          ]
        },
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "(0.4717559695682125, np.float64(0.5733644302274352))"
            ]
          },
          "metadata": {},
          "execution_count": 9
        }
      ],
      "source": [
        "# Code for Naïve and Historical Mean baselines goes here\n",
        "\n",
        "def evaluate(y_true, y_pred, model_name):\n",
        "    mae = mean_absolute_error(y_true, y_pred)\n",
        "    rmse = np.sqrt(mean_squared_error(y_true, y_pred))\n",
        "    print(f\"{model_name:<25} | MAE: {mae:.4f} | RMSE: {rmse:.4f}\")\n",
        "    return mae, rmse\n",
        "\n",
        "print(\"========== DAILY FORECAST BASELINES (Log Scale) ==========\")\n",
        "# Naive Forecast: Pred(T) = Actual(T-1)\n",
        "y_pred_naive_d = X_test_d['lag_1']\n",
        "evaluate(y_test_d, y_pred_naive_d, \"Naïve Forecast\")\n",
        "\n",
        "# Mean Forecast: Pred(T) = Historical Mean\n",
        "y_pred_mean_d = np.repeat(y_train_d.mean(), len(y_test_d))\n",
        "evaluate(y_test_d, y_pred_mean_d, \"Historical Mean\")\n",
        "\n",
        "print(\"\\n========== MONTHLY FORECAST BASELINES (Log Scale) ==========\")\n",
        "y_pred_naive_m = X_test_m['lag_1']\n",
        "evaluate(y_test_m, y_pred_naive_m, \"Naïve Forecast\")\n",
        "y_pred_mean_m = np.repeat(y_train_m.mean(), len(y_test_m))\n",
        "evaluate(y_test_m, y_pred_mean_m, \"Historical Mean\")"
      ]
    },
