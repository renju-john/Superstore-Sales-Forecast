    },
    {
      "cell_type": "code",
      "execution_count": 3,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "zZKaZ6-bLNbO",
        "outputId": "ef8f4f43-459a-42d8-8dd4-95af80b27cec"
      },
      "outputs": [
        {
          "output_type": "stream",
